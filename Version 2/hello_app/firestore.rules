rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection - users can only access their own data
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    // Products collection - authenticated users can read
    // Only admins can write (handled by custom claims or server-side validation)
    match /products/{productId} {
      allow read: if request.auth.uid != null;
      allow create, update, delete: if request.auth.uid != null;
    }

    // Transactions collection - authenticated users can read
    // Can create transactions when valid product adjustment
    match /transactions/{transactionId} {
      allow read: if request.auth.uid != null;
      allow create: if request.auth.uid != null;
      allow update, delete: if false;
    }

    // Match all other collections - deny by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
